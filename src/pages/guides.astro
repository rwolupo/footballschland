---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Guides | Footballschland"
  description="Guides und Evergreen-Artikel rund um American Football: Karrierewege in die NFL, Spieler-Übersichten und mehr – von Footballschland."
  canonical="https://footballschland.de/guides/"
>

  <!-- Hero -->
  <section class="bg-[#231f20] pt-32 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <p class="text-rot text-xs font-bold uppercase tracking-widest mb-3">Guides</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
        Alles was du wissen musst
      </h1>
      <p class="text-white/60 text-lg font-body leading-relaxed">
        Evergreen-Guides zu NFL, NCAA und dem Weg aus Deutschland in den amerikanischen Football.
      </p>
    </div>
  </section>

  <!-- Guide List -->
  <section class="bg-[#faf8f5] py-16 px-4">
    <div class="max-w-3xl mx-auto">

      <a
        href="/weg-in-die-nfl"
        class="group flex flex-col sm:flex-row gap-6 bg-white rounded-2xl border border-[#231f20]/8 p-7 shadow-sm hover:shadow-md transition-shadow mb-6"
      >
        <div class="flex-1">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-rot mb-2">NFL Karriere</span>
          <h2 class="font-display text-2xl font-bold text-[#231f20] group-hover:text-rot transition-colors mb-2">
            Dein Weg in die NFL: Guide für deutsche Talente (2026)
          </h2>
          <p class="text-[#231f20]/65 font-body leading-relaxed text-sm">
            Alle sechs Karrierewege erklärt – vom NFL International Player Pathway über NCAA bis zum direkten Draft aus Europa. Mit echten deutschen Erfolgsbeispielen und den wichtigsten Organisationen.
          </p>
        </div>
        <div class="flex items-center text-rot font-semibold text-sm group-hover:translate-x-1 transition-transform shrink-0 self-end sm:self-center">
          Zum Guide →
        </div>
      </a>

      <!-- Placeholder für weitere Guides -->
      <p class="text-[#231f20]/35 text-sm font-body text-center pt-4">Weitere Guides folgen.</p>

    </div>
  </section>

</BaseLayout>
