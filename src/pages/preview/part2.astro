---
// Lokaler Preview für den Part-2-Artikel.
// Liest die JSON direkt aus content/ (noch nicht in Sanity) und rendert sie
// mit dem gleichen Portable-Text-Setup wie /blockblog/[slug].
//
// Erreichbar unter: http://localhost:4321/preview/part2/
// Nur zum Review vor dem Sanity-Sync gedacht; nicht verlinken.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { toHTML } from '@portabletext/to-html';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const post = JSON.parse(
  readFileSync(resolve('content/blockblog/ai-mock-draft-2026-part2.json'), 'utf8'),
);

const { title, description, pubDate, author, readTime, category, body } = post;
const bodyHtml = body ? toHTML(body) : '';
const categories: string[] = Array.isArray(category) ? category : category ? [category] : [];

const pubDateFormatted = pubDate
  ? new Date(pubDate).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })
  : '';
---

<BaseLayout title={`[PREVIEW] ${title}`} description={description}>
  <article class="bg-[#faf8f5] pt-28 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6 rounded-xl bg-rot/10 border border-rot/30 px-4 py-3 text-sm">
        <p class="font-bold text-rot mb-1">Lokaler Preview</p>
        <p class="text-[#231f20]/70">
          Dieser Artikel liegt noch nicht in Sanity. Quelle:
          <code class="text-rot bg-[#231f20]/5 px-1 rounded">content/blockblog/ai-mock-draft-2026-part2.json</code>
        </p>
      </div>

      <header class="mb-8">
        <div class="flex flex-wrap gap-2 mb-4">
          {categories.map((cat: string) => (
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider rounded bg-rot/10 text-rot border border-rot/20">{cat}</span>
          ))}
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-[#231f20] leading-tight mb-4">{title}</h1>
        {description && <p class="text-[#231f20]/60 text-lg font-body leading-relaxed mb-4">{description}</p>}
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[#231f20]/50 font-body">
          {author && <span>Von <strong class="text-[#231f20]/70">{author}</strong></span>}
          {pubDateFormatted && <span>· {pubDateFormatted}</span>}
          {readTime && <span>· {readTime}</span>}
        </div>
      </header>

      <div
        class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-[#231f20] prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-[#231f20]/15 prose-h2:pb-3 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-rot prose-p:text-[#3a3535] prose-p:leading-relaxed prose-p:font-body prose-a:text-rot prose-a:no-underline hover:prose-a:underline prose-strong:text-[#231f20] prose-blockquote:border-l-4 prose-blockquote:border-rot prose-blockquote:pl-6 prose-blockquote:italic prose-ul:text-[#3a3535] prose-li:my-1 prose-hr:border-[#231f20]/10 prose-code:text-rot prose-code:bg-[#231f20]/5 prose-code:px-1 prose-code:rounded"
        set:html={bodyHtml}
      />
    </div>
  </article>
</BaseLayout>
