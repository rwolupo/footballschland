---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from '../lib/sanity';
import { PAGE_BY_SLUG_QUERY } from '../lib/queries';
import { toHTML } from '@portabletext/to-html';

const page = await sanityClient.fetch(PAGE_BY_SLUG_QUERY, { slug: 'impressum' });
const bodyHtml = page?.body
  ? toHTML(page.body, {
      components: {
        marks: {
          link: ({ children, value }: any) =>
            `<a href="${value?.href}" target="_blank" rel="noopener noreferrer">${children}</a>`,
        },
      },
    })
  : '';
---
<BaseLayout title="Impressum | Footballschland" description="Impressum und rechtliche Angaben für Footballschland.">
  <div class="max-w-3xl mx-auto px-4 py-16 md:py-24">
    <header class="mb-12">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">{page?.title ?? 'Impressum'}</h1>
      <p class="text-white/50 font-body text-sm">Angaben gemäß § 5 TMG</p>
    </header>
    <div
      class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display
        prose-h2:text-xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-3 prose-h2:border-b prose-h2:border-white/10 prose-h2:pb-2
        prose-p:text-white/70 prose-p:leading-relaxed prose-p:font-body
        prose-a:text-crimson hover:prose-a:underline
        prose-ul:text-white/70 prose-li:my-1
        prose-strong:text-white"
      set:html={bodyHtml}
    />
  </div>
</BaseLayout>
