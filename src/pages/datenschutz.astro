---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from '../lib/sanity';
import { PAGE_BY_SLUG_QUERY } from '../lib/queries';
import { toHTML } from '@portabletext/to-html';

const page = await sanityClient.fetch(PAGE_BY_SLUG_QUERY, { slug: 'datenschutz' });
const bodyHtml = page?.body
  ? toHTML(page.body, {
      components: {
        marks: {
          link: ({ children, value }: any) =>
            `<a href="${value?.href}" target="_blank" rel="noopener noreferrer">${children}</a>`,
        },
      },
    })
  : '';
---
<BaseLayout
  title="Datenschutz | Footballschland"
  description="Datenschutzerklärung von Footballschland – American Football MADE IN GERMANY"
>
  <section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-28 pb-8 px-4">
    <div class="max-w-3xl mx-auto">
      <p class="section-label mb-4">Rechtliches</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-white">{page?.title ?? 'Datenschutz'}</h1>
    </div>
  </section>
  <section class="py-12 px-4 bg-[#0D0D0D]">
    <div
      class="max-w-3xl mx-auto
        prose prose-invert prose-lg max-w-none
        prose-headings:font-display
        prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-4
        prose-p:text-white/70 prose-p:leading-relaxed prose-p:font-body
        prose-a:text-crimson hover:prose-a:underline
        prose-ul:text-white/70 prose-li:my-1
        prose-strong:text-white"
      set:html={bodyHtml}
    />
  </section>
</BaseLayout>
