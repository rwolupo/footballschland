---
import { sanityClient } from '../../lib/sanity';
export const prerender = true;
import { ALL_SLUGS_QUERY, POST_BY_SLUG_QUERY } from '../../lib/queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch(ALL_SLUGS_QUERY);
  return slugs.map((item: { slug: string }) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(POST_BY_SLUG_QUERY, { slug });

if (!post) {
  return Astro.redirect('/blockblog');
}

const { title, description, pubDate, updatedDate, author, category, readTime, heroImage, body } = post;

const canonicalUrl = `https://footballschland.de/blockblog/${slug}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonicalUrl}#article`,
      "headline": title,
      "description": description || '',
      "url": canonicalUrl,
      "datePublished": pubDate,
      "dateModified": updatedDate || pubDate,
      "author": {
        "@type": "Person",
        "name": author || 'Daniel Düngel',
        "url": "https://footballschland.de"
      },
      "publisher": {
        "@id": "https://footballschland.de/#organization"
      },
      "image": heroImage?.asset?.url
        ? { "@type": "ImageObject", "url": heroImage.asset.url }
        : { "@type": "ImageObject", "url": "https://footballschland.de/assets/og-default.png" },
      "inLanguage": "de",
      "articleSection": category || 'Football',
      "keywords": category === 'Draft'
        ? "NFL Draft, deutsche Spieler, NFL Draft Deutschland, German NFL prospects"
        : category === 'College'
        ? "College Football, deutsche Talente, D1 College Football Deutschland, German college football players"
        : "American Football Deutschland, GFL, ELF, NFL"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://footballschland.de" },
        { "@type": "ListItem", "position": 2, "name": "Blockblog", "item": "https://footballschland.de/blockblog" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
      ]
    }
  ]
};

// FAQ-Schema je Artikel (GEO: KI-Systeme lieben strukturierte Q&A)
const faqData: Record<string, { q: string; a: string }[]> = {
  'deutsche-talente-d1-2025': [
    {
      q: 'Wie viele deutsche Spieler spielen in D1 College Football 2025?',
      a: 'In der Saison 2025 stehen erstmals über 50 deutsche Talente in den Kadern der NCAA Division 1 – genau 53 Spieler, verteilt auf 30 FBS- und 23 FCS-Programme.'
    },
    {
      q: 'Welche Position spielen die meisten deutschen D1-Footballer?',
      a: 'Mit Abstand die meisten deutschen Spieler in D1 spielen auf der Offensive Line (18 Spieler), gefolgt von Defensive Line (12) und Tight End (7). Deutsche Athleten überzeugen vor allem durch ihre Körpergröße und Athletik im Lineman-Bereich.'
    },
    {
      q: 'In welchen Conferences spielen die meisten deutschen D1-Spieler?',
      a: 'Im FBS dominiert die SEC mit 7 deutschen Spielern, gefolgt von Sun Belt und AAC mit je 5. Im FCS führen SoCon und Big Sky mit je 4 Spielern.'
    },
    {
      q: 'Was ist der Unterschied zwischen FBS und FCS im College Football?',
      a: 'FBS (Football Bowl Subdivision) ist die höchste Spielklasse mit den größten Programmen wie Alabama, Michigan oder Georgia. FCS (Football Championship Subdivision) ist die zweite Division mit starken Programmen wie North Dakota State. Von 53 deutschen D1-Spielern 2025 spielen 30 in der FBS und 23 in der FCS.'
    },
    {
      q: 'Welcher deutsche Spieler hat die beste NFL-Draft-Chance aus D1 College Football 2025?',
      a: 'Mehrere deutsche D1-Spieler stehen vor dem NFL Draft 2026. Tight End Marlin Klein von der University of Michigan gilt als potenzieller Dritt-Runden-Pick und ist der prominenteste deutsche NFL-Draft-Kandidat aus der Saison 2025.'
    }
  ],
  'deutsche-spieler-im-nfl-draft-2026': [
    {
      q: 'Wie viele deutsche Spieler sind im NFL Draft 2026?',
      a: 'Sieben deutsche Spieler wollen beim NFL Draft 2026 den Sprung in die NFL schaffen: Marlin Klein (TE, Michigan), Paul Rubelt (OL, UCF), Mark Petry (OL, Syracuse), Florian Staehler (OL, Idaho), Maurice Heims (DL, Idaho), Felix Lepper (OL, IPP) und Leo Blumentritt (P/K, Northern Colorado).'
    },
    {
      q: 'Wer ist der beste deutsche NFL Draft Kandidat 2026?',
      a: 'Marlin Klein (Tight End, University of Michigan) gilt als bester deutscher NFL-Draft-Kandidat 2026. Mit 47 Receptions, 584 Yards und 7 Touchdowns in der Saison 2025 sowie einer 4,61-Sekunden-Zeit im 40-Yard-Dash (bei 6\'6" und 253 lbs) ist ein Pick in der 3. Runde realistisch.'
    },
    {
      q: 'Was ist das International Player Pathway Program (IPP) der NFL?',
      a: 'Das International Player Pathway Program (IPP) der NFL ermöglicht internationalen Spielern ohne US-College-Erfahrung den Einstieg in die NFL. Spieler absolvieren ein intensives Trainingsprogramm und können als zusätzlicher Practice-Squad-Spieler verpflichtet werden. 2026 nimmt Felix Lepper (OL, 6\'9") aus Deutschland am IPP teil.'
    },
    {
      q: 'Wo kommen die deutschen NFL Draft Kandidaten 2026 her?',
      a: 'Die sieben deutschen NFL-Draft-Kandidaten 2026 kommen aus ganz Deutschland: Marlin Klein aus Köln, Paul Rubelt aus Frankfurt an der Oder, Mark Petry aus Hochheim am Main (Hessen), Florian Staehler aus Leverkusen, Maurice Heims aus Hamburg, Felix Lepper aus Witzenhausen und Leo Blumentritt aus Weichs (Bayern). Sie repräsentieren die wachsende Footballkultur quer durch die Bundesrepublik.'
    },
    {
      q: 'Wird der NFL Draft 2026 in Deutschland live im TV übertragen?',
      a: 'Ja! RTL überträgt den NFL Draft 2026 an Tag 1 und Tag 2 live im Free-TV und auf RTL+. Da Marlin Klein als potenzieller Dritt-Runden-Pick gehandelt wird und der Pick realistisch an Tag 2 fallen könnte, besteht eine gute Chance, seinen historischen Moment live mitzuerleben. Alle sieben deutschen Kandidaten können an Tag 2 oder Tag 3 gepickt oder als UDFA unter Vertrag genommen werden.'
    },
    {
      q: 'Wie kann man den NFL Draft 2026 mit deutschen Spielern verfolgen?',
      a: 'Den NFL Draft 2026 mit deutschen Spielern verfolgt man am besten über RTL (live Tag 1 & 2 im Free-TV und auf RTL+) sowie über den Footballschland Podcast und Blockblog. Footballschland berichtet exklusiv über deutsche Talente in High School, College und NFL – auf Deutsch, mit Hintergrundgeschichten und Interviews.'
    }
  ]
};
const faqItems = faqData[slug as string] || [];
const faqSchema = faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
} : null;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const categoryColors: Record<string, string> = {
  Draft: 'bg-crimson/20 text-crimson border-crimson/40',
  NFL: 'bg-blue-900/50 text-blue-400 border-blue-700',
  College: 'bg-emerald-900/50 text-emerald-400 border-emerald-700',
};
const badgeClass = categoryColors[category] ?? 'bg-white/10 text-white/60 border-white/20';

// Autoren — Mehrfach-Autoren-Unterstützung
const authorOverrides: Record<string, string> = {
  'deutsche-talente-d1-2025': 'Sandra Janat & Daniel Düngel',
};
const displayAuthor = authorOverrides[slug as string] || author || 'Daniel Düngel';
const authorList = displayAuthor.split(/\s*&\s*/).map((a: string) => a.trim());
const authorAvatars: Record<string, string> = {
  'Daniel Düngel': '/assets/fbs%20daniel_edited_edited.jpg',
  'Sandra Janat':  '/assets/fbs%20sandra_edited.jpg',
};

// Extract unique conferences and divisions from player cards for filter UI
const playerCards = (body || []).filter((b: any) => b._type === 'playerCard');
const conferences = [...new Set(playerCards.map((c: any) => c.conference).filter(Boolean))] as string[];
const divisions = [...new Set(playerCards.map((c: any) => c.division).filter(Boolean))] as string[];
const hasFilters = playerCards.length > 1 && (conferences.length > 1 || divisions.length > 1);

// Stats block — nur rendern wenn ≥5 Spielerkarten vorhanden
const hasStats = playerCards.length >= 5;

// Positionen
const posCounts: Record<string, number> = {};
for (const pc of playerCards) {
  const pos = ((pc.position as string) || 'Unbekannt').trim();
  posCounts[pos] = (posCounts[pos] || 0) + 1;
}
const sortedPos = Object.entries(posCounts).sort((a, b) => b[1] - a[1]);
const maxPosCount = sortedPos[0]?.[1] ?? 1;

// Division FBS / FCS — Sanity speichert "D1-FBS" / "D1-FCS"
const isFbs = (div: string) => (div || '').toUpperCase().includes('FBS');
const isFcs = (div: string) => (div || '').toUpperCase().includes('FCS');
const fbsCount = playerCards.filter((pc: any) => isFbs(pc.division as string)).length;
const fcsCount = playerCards.filter((pc: any) => isFcs(pc.division as string)).length;
const totalCount = playerCards.length;
const fbsPct = totalCount > 0 ? Math.round((fbsCount / totalCount) * 100) : 0;
const fcsPct = totalCount > 0 ? Math.round((fcsCount / totalCount) * 100) : 0;

// Conferences (FBS + FCS getrennt)
const fbsConfs: Record<string, number> = {};
const fcsConfs: Record<string, number> = {};
for (const pc of playerCards) {
  const conf = ((pc.conference as string) || 'Unbekannt').trim();
  const div = (pc.division as string) || '';
  if (isFbs(div)) fbsConfs[conf] = (fbsConfs[conf] || 0) + 1;
  else fcsConfs[conf] = (fcsConfs[conf] || 0) + 1;
}
const sortedFbs = Object.entries(fbsConfs).sort((a, b) => b[1] - a[1]);
const sortedFcs = Object.entries(fcsConfs).sort((a, b) => b[1] - a[1]);

// Bio-Text: Absätze + Links + Projection-Box formatieren
function renderBio(bio: string): string {
  if (!bio) return '';

  // Podcast-Episode → Spotify-URL Mapping
  const episodeLinks: Record<string, string> = {
    'S03E12': 'https://open.spotify.com/episode/6Z2IpliQE2qztM2DVaqDAL',
    'S01E72': 'https://open.spotify.com/episode/7Ihm51GaeZCv82RPlotTYx',
    'S03E03': 'https://open.spotify.com/episode/0TzjtRLDH6Ts2hYrNk55SP',
  };

  // Externe Organisations-Links
  const orgLinks: Record<string, string> = {
    'Gridiron Imports Foundation': 'https://gridironimports.com',
    'Gridiron Imports': 'https://gridironimports.com',
    'PPI Recruits': 'https://ppirecruits.com',
    'Hamburg Sea Devils': 'https://www.instagram.com/hamburgseadevils/',
    'NFL International Player Pathway': 'https://operations.nfl.com/journey-to-the-nfl/international-player-pathway-program/',
    'International Player Pathway Programme': 'https://operations.nfl.com/journey-to-the-nfl/international-player-pathway-program/',
    'International Player Pathway Program': 'https://operations.nfl.com/journey-to-the-nfl/international-player-pathway-program/',
    'International Pathway Programmes': 'https://operations.nfl.com/journey-to-the-nfl/international-player-pathway-program/',
  };

  const paragraphs = bio.split(/\n\n+/).filter(p => p.trim());

  return paragraphs.map(para => {
    let p = para.trim();

    // Footballschland Projection → hervorgehobene Box
    if (p.startsWith('Footballschland Projection:')) {
      const content = p.replace('Footballschland Projection:', '').trim();
      return `<div class="mt-4 mb-0 flex items-start gap-2 px-3 py-2 bg-[#e31837]/8 border-l-2 border-[#e31837] rounded-r text-sm"><span class="shrink-0 font-semibold text-[#e31837] whitespace-nowrap">🏈 Projection:</span><span class="text-[#231f20]/80">${content}</span></div>`;
    }

    // Pro Day Zeile → Info-Badge
    if (p.startsWith('Pro Day:')) {
      const content = p.replace('Pro Day:', '').trim();
      return `<p class="mt-3 mb-0 text-xs font-semibold text-[#231f20]/50 uppercase tracking-wide">📅 Pro Day: <span class="font-bold text-[#231f20]/70">${content}</span></p>`;
    }

    // Early Projection (ohne Footballschland-Prefix)
    if (p.startsWith('Early Projection:')) {
      const content = p.replace('Early Projection:', '').trim();
      return `<div class="mt-4 mb-0 flex items-start gap-2 px-3 py-2 bg-[#e31837]/8 border-l-2 border-[#e31837] rounded-r text-sm"><span class="shrink-0 font-semibold text-[#e31837] whitespace-nowrap">🏈 Projection:</span><span class="text-[#231f20]/80">${content}</span></div>`;
    }

    // Podcast-Episode-Links einfügen
    for (const [ep, url] of Object.entries(episodeLinks)) {
      const re = new RegExp(`(Folge ${ep})`, 'g');
      p = p.replace(re, `<a href="${url}" target="_blank" rel="noopener noreferrer" class="text-[#e31837] hover:underline font-medium">$1 ↗</a>`);
    }

    // Organisations-Links (längste zuerst, um Teilübereinstimmungen zu vermeiden)
    const sortedOrgs = Object.entries(orgLinks).sort((a, b) => b[0].length - a[0].length);
    for (const [org, url] of sortedOrgs) {
      if (p.includes(org)) {
        p = p.replace(new RegExp(org.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'),
          `<a href="${url}" target="_blank" rel="noopener noreferrer" class="text-[#e31837] hover:underline font-medium">${org} ↗</a>`);
      }
    }

    // \n innerhalb eines Absatzes → <br>
    p = p.replace(/\n/g, '<br>');

    return `<p class="mb-3 last:mb-0">${p}</p>`;
  }).join('');
}

// Portable Text → HTML mit Custom Blocks
const bodyHtml = body ? toHTML(body, {
  components: {
    types: {
      playerCard: ({ value }: any) => {
        const { playerName = '', position = '', yearStatus = '', college = '', conference = '', division = '', externalImageUrls, images, bio = '' } = value;
        const allUrls = [
          ...(externalImageUrls || []),
          ...(images || []).filter((i: any) => i.asset?.url).map((i: any) => i.asset.url),
        ];
        const imgs = allUrls.map((url: string) =>
          `<img src="${url}" alt="${playerName} Spielerkarte" class="w-full rounded-lg cursor-pointer hover:opacity-90 transition-opacity" loading="lazy" onclick="openLightbox('${url.replace(/'/g, "\\'")}')" />`
        ).join('');
        return `
          <div class="player-card not-prose my-8 rounded-xl overflow-hidden border border-[#231f20]/15 bg-white shadow-sm" data-conference="${conference}" data-division="${division}">
            <div class="px-5 py-4 border-b border-[#231f20]/10">
              <p class="font-display text-xl font-bold text-[#231f20] leading-tight">${playerName}</p>
              <p class="text-[#231f20]/60 text-sm mt-0.5">${position}${yearStatus ? ` · ${yearStatus}` : ''}</p>
              ${college ? `<p class="text-[#231f20]/40 text-xs mt-0.5">${college}</p>` : ''}
              ${(conference || division) ? `<p class="text-[#231f20]/40 text-xs mt-1 font-medium">${[conference, division].filter(Boolean).join(' · ')}</p>` : ''}
            </div>
            ${allUrls.length > 0 ? `<div class="grid grid-cols-1 sm:grid-cols-3 gap-2 p-3 bg-[#f5f3f0]">${imgs}</div>` : ''}
            ${bio ? `<div class="px-5 py-5 text-[#231f20]/70 text-sm font-body leading-relaxed space-y-0">${renderBio(bio)}</div>` : ''}
          </div>
        `;
      },
      imageGallery: ({ value }: any) => {
        const { caption = '', images } = value;
        const imgs = (images || [])
          .filter((i: any) => i.asset?.url)
          .map((i: any) => `
            <figure class="snap-start">
              <img src="${i.asset.url}" alt="${i.alt || i.caption || ''}" class="w-full rounded-lg object-cover" loading="lazy" />
              ${i.caption ? `<figcaption class="text-center text-xs text-[#231f20]/50 mt-1">${i.caption}</figcaption>` : ''}
            </figure>
          `).join('');
        return `
          <div class="not-prose my-8">
            ${caption ? `<p class="font-display font-bold text-[#231f20] mb-3">${caption}</p>` : ''}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 overflow-x-auto snap-x snap-mandatory">
              ${imgs}
            </div>
          </div>
        `;
      },
      playerTable: ({ value }: any) => {
        const { tableTitle = '', players } = value;
        const count = (players || []).length;
        const rows = (players || []).map((p: any) => `
          <tr class="border-b border-[#231f20]/10 hover:bg-[#231f20]/5">
            <td class="py-2 pr-4 font-semibold text-[#231f20] text-sm">${p.name || ''}</td>
            <td class="py-2 pr-4 text-[#231f20]/60 text-sm">${p.position || ''}</td>
            <td class="py-2 pr-4 text-[#231f20]/60 text-sm">${p.yearStatus || ''}</td>
            <td class="py-2 text-[#231f20]/60 text-sm">${p.college || ''}</td>
          </tr>
        `).join('');
        return `
          <div class="not-prose my-8">
            <details class="group rounded-xl border border-[#231f20]/10 overflow-hidden">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-white hover:bg-[#231f20]/3 transition-colors list-none">
                <div class="flex items-center gap-3">
                  <span class="font-display font-bold text-[#231f20] text-base">
                    ${tableTitle || 'Alle Spieler'}
                  </span>
                  <span class="px-2 py-0.5 rounded-full bg-[#231f20]/8 text-[#231f20]/60 text-xs font-semibold">${count} Spieler</span>
                </div>
                <span class="text-[#231f20]/40 text-sm font-medium group-open:hidden">Tabelle anzeigen ↓</span>
                <span class="text-[#231f20]/40 text-sm font-medium hidden group-open:inline">Einklappen ↑</span>
              </summary>
              <div class="overflow-x-auto border-t border-[#231f20]/10">
                <table class="w-full text-left">
                  <thead class="bg-[#231f20]/3">
                    <tr>
                      <th class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-[#231f20]/50">Name</th>
                      <th class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-[#231f20]/50">Pos.</th>
                      <th class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-[#231f20]/50">Status</th>
                      <th class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-[#231f20]/50">College</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white">${rows}</tbody>
                </table>
              </div>
            </details>
          </div>
        `;
      },
      image: ({ value }: any) => {
        const url = value.asset?.url;
        if (!url) return '';
        return `
          <figure class="not-prose my-6">
            <img src="${url}" alt="${value.alt || value.caption || ''}" class="w-full rounded-xl shadow-md" loading="lazy" />
            ${value.caption ? `<figcaption class="text-center text-sm text-[#231f20]/50 mt-2">${value.caption}</figcaption>` : ''}
          </figure>
        `;
      },
    },
    marks: {
      link: ({ children, value }: any) => {
        const blank = value?.blank !== false ? ' target="_blank" rel="noopener noreferrer"' : '';
        return `<a href="${value?.href}"${blank}>${children}</a>`;
      },
    },
  },
}) : '';
---

<BaseLayout
  title={`${title} | Footballschland Blockblog`}
  description={description}
  canonical={canonicalUrl}
  ogImage={heroImage?.asset?.url || '/assets/og-default.png'}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}

  <!-- Article Hero — Full Bleed wie Startseite -->
  <section class="relative min-h-[72vh] flex flex-col justify-end bg-[#0D0D0D] pt-20 pb-14 px-4 overflow-hidden">
    <!-- Hero Background Image -->
    {heroImage?.asset?.url ? (
      <img
        src={heroImage.asset.url}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center opacity-30 pointer-events-none"
        aria-hidden="true"
        loading="eager"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-rot/20 to-[#231f20]/60 pointer-events-none"></div>
    )}

    <!-- Gradient-Overlays für Tiefe + sanfter Übergang nach unten -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D0D0D]/75 via-[#0D0D0D]/25 to-[#0D0D0D]/80 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-[#faf8f5] pointer-events-none"></div>

    <!-- Atmosphärische Glows -->
    <div class="absolute top-1/3 right-0 w-[500px] h-[500px] bg-crimson/6 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-gold/4 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-3xl mx-auto w-full">
      <!-- Category + Meta -->
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class={`px-3 py-1 text-xs font-bold uppercase tracking-widest rounded border ${badgeClass}`}>
          {category}
        </span>
        <span class="text-white/50 text-sm font-body">{formatDate(pubDate)}</span>
        {readTime && <span class="text-white/50 text-sm font-body">· {readTime}</span>}
      </div>

      <!-- Title -->
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 drop-shadow-lg">
        {title}
      </h1>

      <!-- Author(en) -->
      <div class="flex items-center gap-3">
        <div class="flex" style={authorList.length > 1 ? 'gap: 0; margin-right: 4px;' : ''}>
          {authorList.map((name, i) => (
            <div
              class="w-9 h-9 rounded-full overflow-hidden shadow-lg ring-2 ring-white/20 bg-crimson"
              style={i > 0 ? 'margin-left: -10px;' : ''}
            >
              {authorAvatars[name]
                ? <img src={authorAvatars[name]} alt={name} class="w-full h-full object-cover object-top" />
                : <span class="w-full h-full flex items-center justify-center text-white font-bold text-xs font-display">
                    {name.split(' ').map((n: string) => n[0]).join('')}
                  </span>
              }
            </div>
          ))}
        </div>
        <div>
          <p class="text-white text-sm font-semibold font-body">{displayAuthor}</p>
          {updatedDate && (
            <p class="text-white/40 text-xs font-body">Aktualisiert: {formatDate(updatedDate)}</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-12 px-4 bg-[#faf8f5] text-[#231f20]">
    <div class="max-w-3xl mx-auto">

      {hasStats && (
        <div class="not-prose mb-10 rounded-2xl overflow-hidden border border-[#231f20]/10 bg-white shadow-sm">

          <!-- Header -->
          <div class="px-6 py-4 bg-[#231f20] flex items-center gap-3">
            <span class="text-crimson font-bold">▪</span>
            <p class="font-display font-bold text-white text-sm tracking-widest uppercase">Statistiken &middot; {totalCount} deutsche Spieler im D1 Football 2025</p>
          </div>

          <!-- 3-Spalten-Grid: FBS Confs | Zahlen + Positionen | FCS Confs -->
          <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[#231f20]/10">

            <!-- Spalte 1: FBS Conferences -->
            <div class="p-5">
              <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-crimson mb-3">FBS · Bowl Subdivision</p>
              {sortedFbs.map(([conf, count]) => (
                <div class="flex items-center justify-between py-[5px] border-b border-[#231f20]/5 last:border-0">
                  <span class="text-xs text-[#231f20]/70">{conf}</span>
                  <span class="text-xs font-bold text-crimson">{count}</span>
                </div>
              ))}
            </div>

            <!-- Spalte 2: FBS/FCS Zahlen + Positionen -->
            <div class="p-5 flex flex-col gap-5">
              <!-- Gesamtzahlen -->
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#231f20]/40 mb-3">Division-Split</p>
                <div class="flex items-end gap-8 mb-3">
                  <div class="text-center">
                    <p class="font-display text-5xl font-black text-crimson leading-none">{fbsCount}</p>
                    <p class="text-xs font-bold text-[#231f20]/50 mt-1">FBS</p>
                  </div>
                  <div class="text-center">
                    <p class="font-display text-5xl font-black text-blue-500 leading-none">{fcsCount}</p>
                    <p class="text-xs font-bold text-[#231f20]/50 mt-1">FCS</p>
                  </div>
                </div>
                <div class="h-2 rounded-full overflow-hidden bg-[#231f20]/10 flex">
                  <div class="h-full bg-crimson" style={`width:${fbsPct}%`}></div>
                  <div class="h-full bg-blue-500" style={`width:${fcsPct}%`}></div>
                </div>
                <div class="flex justify-between mt-1">
                  <span class="text-[10px] text-[#231f20]/40">FBS {fbsPct}%</span>
                  <span class="text-[10px] text-[#231f20]/40">FCS {fcsPct}%</span>
                </div>
              </div>
              <!-- Positionen -->
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#231f20]/40 mb-3">Spieler je Position</p>
                <div class="space-y-[6px]">
                  {sortedPos.map(([pos, count]) => (
                    <div class="flex items-center gap-2">
                      <span class="w-10 text-right text-[11px] font-bold text-[#231f20]/50 shrink-0">{pos}</span>
                      <div class="flex-1 h-[6px] bg-[#231f20]/10 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-crimson" style={`width:${Math.round((count / maxPosCount) * 100)}%`}></div>
                      </div>
                      <span class="w-4 text-right text-[11px] font-bold text-[#231f20]">{count}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- Spalte 3: FCS Conferences -->
            <div class="p-5">
              <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-blue-500 mb-3">FCS · Championship Subdiv.</p>
              {sortedFcs.map(([conf, count]) => (
                <div class="flex items-center justify-between py-[5px] border-b border-[#231f20]/5 last:border-0">
                  <span class="text-xs text-[#231f20]/70">{conf}</span>
                  <span class="text-xs font-bold text-blue-500">{count}</span>
                </div>
              ))}
            </div>

          </div>
        </div>
      )}

      {hasFilters && (
        <div id="player-filter" class="mb-8 p-4 bg-white rounded-xl border border-[#231f20]/10 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-[#231f20]/40 mb-3">Spieler filtern</p>
          <div class="flex flex-wrap gap-2" id="filter-buttons">
            <button class="filter-btn active" data-type="all">Alle</button>
            {conferences.map(conf => (
              <button class="filter-btn" data-type="conference" data-value={conf}>{conf}</button>
            ))}
            {divisions.map(div => (
              <button class="filter-btn" data-type="division" data-value={div}>{div}</button>
            ))}
          </div>
        </div>
      )}

      <div
        class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-[#231f20] prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-[#231f20]/15 prose-h2:pb-3 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-rot prose-p:text-[#3a3535] prose-p:leading-relaxed prose-p:font-body prose-a:text-rot prose-a:no-underline hover:prose-a:underline prose-strong:text-[#231f20] prose-blockquote:border-l-4 prose-blockquote:border-rot prose-blockquote:pl-6 prose-blockquote:italic prose-ul:text-[#3a3535] prose-li:my-1 prose-hr:border-[#231f20]/10 prose-code:text-rot prose-code:bg-[#231f20]/5 prose-code:px-1 prose-code:rounded prose-img:rounded-xl prose-img:shadow-md"
        set:html={bodyHtml}
      />

      {faqItems.length > 0 && (
        <div class="not-prose mt-12 rounded-2xl overflow-hidden border border-[#231f20]/10 bg-white shadow-sm">
          <div class="px-6 py-4 bg-[#231f20] flex items-center gap-3">
            <span class="text-gold font-bold text-lg">?</span>
            <p class="font-display font-bold text-white text-sm tracking-widest uppercase">Häufige Fragen</p>
          </div>
          <div class="divide-y divide-[#231f20]/8">
            {faqItems.map(({ q, a }) => (
              <details class="group px-6 py-4 cursor-pointer">
                <summary class="flex items-center justify-between gap-4 font-semibold text-[#231f20] text-sm list-none select-none">
                  <span>{q}</span>
                  <span class="shrink-0 text-[#231f20]/30 group-open:text-crimson text-lg transition-colors">+</span>
                </summary>
                <p class="mt-3 text-sm text-[#231f20]/70 leading-relaxed font-body">{a}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-[#231f20]/10 flex flex-wrap gap-3">
        <a href="/blockblog" class="px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded border bg-[#231f20]/5 text-[#231f20]/60 border-[#231f20]/20 hover:border-[#231f20]/40">← Alle Artikel</a>
        <span class={`px-3 py-1 text-xs font-bold uppercase tracking-wider rounded border ${badgeClass}`}>{category}</span>
      </div>

      <div class="mt-8 p-6 bg-[#231f20]/5 border border-[#231f20]/10 rounded-xl">
        <p class="text-[#231f20]/60 text-sm font-body mb-3">Artikel teilen:</p>
        <div class="flex flex-wrap gap-3">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent('https://footballschland.de/blockblog/' + slug)}&via=footballschland`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-[#1DA1F2]/10 border border-[#1DA1F2]/30 text-[#1DA1F2] text-sm rounded hover:bg-[#1DA1F2]/20 transition-colors">𝕏 Twitter</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://footballschland.de/blockblog/' + slug)}`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-[#1877F2]/10 border border-[#1877F2]/30 text-[#1877F2] text-sm rounded hover:bg-[#1877F2]/20 transition-colors">Facebook</a>
        </div>
      </div>
    </div>
  </article>

  <section class="py-16 px-4 bg-gradient-to-b from-[#0D0D0D] to-[#1A1A1A]">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="section-label mb-3">Unterstützt uns</h2>
      <h3 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Mehr deutsches <span class="text-crimson">Football?</span></h3>
      <p class="text-white/60 font-body mb-6">Hört unseren Podcast, nutzt unsere Partner-Links und werdet Teil der Footballschland-Community.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/episoden" class="btn-episodes">Podcast hören</a>
        <a href="/partner" class="btn-gold">Unsere Partner</a>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 hidden" onclick="if(event.target===this)closeLightbox()">
    <button class="absolute top-4 right-4 text-white/80 hover:text-white text-4xl font-bold leading-none z-10" onclick="closeLightbox()">×</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] rounded-lg shadow-2xl object-contain" />
  </div>

</BaseLayout>

<style>
  .filter-btn {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0.25rem;
    border: 1px solid rgba(35,31,32,0.2);
    background: rgba(35,31,32,0.05);
    color: rgba(35,31,32,0.6);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: rgba(35,31,32,0.4); background: rgba(35,31,32,0.1); }
  .filter-btn.active { background: rgba(220,20,60,0.1); color: #dc143c; border-color: rgba(220,20,60,0.4); }
</style>

<script>
  function openLightbox(src: string) {
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    if (lb && img) { img.src = src; lb.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  }
  function closeLightbox() {
    const lb = document.getElementById('lightbox');
    if (lb) { lb.classList.add('hidden'); document.body.style.overflow = ''; }
  }
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  (window as any).openLightbox = openLightbox;
  (window as any).closeLightbox = closeLightbox;

  let activeType = 'all';
  let activeValue = '';
  function applyFilter() {
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const el = btn as HTMLElement;
      el.classList.remove('active');
      if (activeType === 'all' && el.dataset.type === 'all') el.classList.add('active');
      if (el.dataset.type === activeType && el.dataset.value === activeValue) el.classList.add('active');
    });
    document.querySelectorAll('.player-card').forEach(card => {
      const el = card as HTMLElement;
      if (activeType === 'all') { el.style.display = ''; return; }
      const val = el.dataset[activeType] || '';
      el.style.display = val === activeValue ? '' : 'none';
    });
  }
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const type = el.dataset.type || 'all';
      const value = el.dataset.value || '';
      if (type === activeType && value === activeValue) { activeType = 'all'; activeValue = ''; }
      else { activeType = type; activeValue = value; }
      applyFilter();
    });
  });
</script>
