---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, description, pubDate, updatedDate, author, category, readTime, heroImage } = post.data;

// Format dates
const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const categoryColors: Record<string, string> = {
  'Draft': 'bg-crimson/20 text-crimson border-crimson/40',
  'NFL': 'bg-blue-900/50 text-blue-400 border-blue-700',
  'College': 'bg-emerald-900/50 text-emerald-400 border-emerald-700',
};
const badgeClass = categoryColors[category] || 'bg-white/10 text-white/60 border-white/20';
---

<BaseLayout
  title={`${title} | Footballschland Blockblog`}
  description={description}
>

<!-- Article Hero -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-28 pb-0 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- Category + Meta -->
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class={`px-3 py-1 text-xs font-bold uppercase tracking-widest rounded border ${badgeClass}`}>
        {category}
      </span>
      <span class="text-white/40 text-sm font-body">{formatDate(pubDate)}</span>
      {readTime && <span class="text-white/40 text-sm font-body">· {readTime}</span>}
    </div>

    <!-- Title -->
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
      {title}
    </h1>

    <!-- Author -->
    <div class="flex items-center gap-3 mb-8">
      <div class="w-9 h-9 rounded-full bg-crimson flex items-center justify-center text-white font-bold text-sm font-display">
        DD
      </div>
      <div>
        <p class="text-white text-sm font-semibold font-body">{author}</p>
        {updatedDate && (
          <p class="text-white/40 text-xs font-body">Aktualisiert: {formatDate(updatedDate)}</p>
        )}
      </div>
    </div>

    <!-- Hero Image (Gradient-Fallback wenn Bild fehlt) -->
    <div class="w-full aspect-[16/9] rounded-xl overflow-hidden mb-0 relative bg-gradient-to-br from-rot/30 to-[#231f20]">
      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover"
          onerror="this.style.display='none'"
        />
      )}
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="opacity: var(--fallback-opacity, 1)">
        <span class="font-display text-white/20 text-6xl font-bold">FS</span>
      </div>
    </div>
  </div>
</section>

<!-- Article Content — helles Layout für Lesbarkeit -->
<article class="py-12 px-4 bg-[#faf8f5] text-[#231f20]">
  <div class="max-w-3xl mx-auto">
    <div class="prose prose-lg max-w-none
      prose-headings:font-display prose-headings:text-[#231f20]
      prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-[#231f20]/15 prose-h2:pb-3
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-rot
      prose-p:text-[#3a3535] prose-p:leading-relaxed prose-p:font-body
      prose-a:text-rot prose-a:no-underline hover:prose-a:underline
      prose-strong:text-[#231f20]
      prose-blockquote:border-l-4 prose-blockquote:border-rot prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-[#3a3535]/80 prose-blockquote:bg-rot/5 prose-blockquote:py-1
      prose-ul:text-[#3a3535] prose-li:my-1
      prose-hr:border-[#231f20]/10
      prose-code:text-rot prose-code:bg-[#231f20]/5 prose-code:px-1 prose-code:rounded
      prose-img:rounded-xl prose-img:shadow-md
    ">
      <Content />
    </div>

    <!-- Tags / Categories -->
    <div class="mt-12 pt-8 border-t border-[#231f20]/10 flex flex-wrap gap-3">
      <a href="/blockblog" class="px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded border bg-[#231f20]/5 text-[#231f20]/60 border-[#231f20]/20 hover:border-rot/50 hover:text-rot transition-colors">
        ← Alle Artikel
      </a>
      <span class={`px-3 py-1 text-xs font-bold uppercase tracking-wider rounded border ${badgeClass}`}>
        {category}
      </span>
    </div>

    <!-- Social Share -->
    <div class="mt-8 p-6 bg-[#231f20]/5 border border-[#231f20]/10 rounded-xl">
      <p class="text-[#231f20]/60 text-sm font-body mb-3">Artikel teilen:</p>
      <div class="flex flex-wrap gap-3">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent('https://footballschland.netlify.app/blockblog/' + post.slug)}&via=footballschland`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-[#1DA1F2]/10 border border-[#1DA1F2]/30 text-[#1DA1F2] text-sm rounded hover:bg-[#1DA1F2]/20 transition-colors font-body"
        >
          𝕏 Twitter
        </a>
        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://footballschland.netlify.app/blockblog/' + post.slug)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-[#1877F2]/10 border border-[#1877F2]/30 text-[#1877F2] text-sm rounded hover:bg-[#1877F2]/20 transition-colors font-body"
        >
          Facebook
        </a>
      </div>
    </div>
  </div>
</article>

<!-- CTA -->
<section class="py-16 px-4 bg-gradient-to-b from-[#0D0D0D] to-[#1A1A1A]">
  <div class="max-w-2xl mx-auto text-center">
    <p class="section-label mb-3">Unterstützt uns</p>
    <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
      Mehr deutsches Football?
    </h2>
    <p class="text-white/60 font-body mb-6">
      Hört unseren Podcast, nutzt unsere Partner-Links und werdet Teil der Footballschland-Community.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/episoden" class="btn-primary">Podcast hören</a>
      <a href="/partner" class="btn-outline">Unsere Partner</a>
    </div>
  </div>
</section>

</BaseLayout>
