---
export const prerender = true;
import { sanityClient } from '../../lib/sanity';
import { ALL_POSTS_QUERY } from '../../lib/queries';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await sanityClient.fetch(ALL_POSTS_QUERY);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const categoryColors: Record<string, string> = {
  Draft: 'bg-crimson/20 text-crimson border-crimson/40',
  'NFL Draft': 'bg-crimson/20 text-crimson border-crimson/40',
  NFL: 'bg-blue-900/50 text-blue-400 border-blue-700',
  College: 'bg-emerald-900/50 text-emerald-400 border-emerald-700',
  Podcast: 'bg-purple-900/50 text-purple-400 border-purple-700',
  'High School': 'bg-amber-900/50 text-amber-400 border-amber-700',
  Feature: 'bg-white/10 text-white/60 border-white/20',
};
---

<BaseLayout
  title="Blockblog – Artikel über deutsche Football-Talente"
  description="Analysen, Portraits & News zu deutschen Spielern in College Football, NFL Draft, GFL und ELF. Der Footballschland Blockblog – deine Quelle für German Football."
  canonical="https://footballschland.de/blockblog/"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-[#1A1A1A] to-[#111111] pt-28 pb-12 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="section-label mb-4">Blockblog</h2>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
        Alle <span class="text-gold">Artikel</span>
      </h1>
      <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto font-body leading-relaxed">
        Der Blockblog ist unser Zuhause für Artikel über deutsche Talente im American Football.
        Von ausführlichen Berichten über unsere Podcast-Themen bis zu umfassenden Spieler-Übersichten.
      </p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-6 px-4 bg-[#111111] border-b border-white/10">
    <div class="max-w-4xl mx-auto flex flex-wrap gap-2 justify-center">
      <a href="/blockblog" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-crimson/20 text-crimson border-crimson/40">Alle Beiträge</a>
      <a href="/blockblog/categories/draft" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-white/40">Draft</a>
      <a href="/blockblog/categories/nfl" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-white/40">NFL</a>
      <a href="/blockblog/categories/college" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-white/40">College</a>
      <a href="/blockblog/categories/podcast" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-purple-900/30 text-purple-400 border-purple-700/40 hover:border-purple-500">Podcast</a>
      <a href="/blockblog/categories/high-school" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-amber-900/30 text-amber-400 border-amber-700/40 hover:border-amber-500">High School</a>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-16 px-4 bg-[#0D0D0D]">
    <div class="max-w-4xl mx-auto">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-white/40 font-body text-lg">Keine Beiträge gefunden.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-8">
          {posts.map((post: any) => {
            const cats: string[] = Array.isArray(post.category) ? post.category : post.category ? [post.category] : [];
            const badgeClass = categoryColors[cats[0]] ?? 'bg-white/10 text-white/60 border-white/20';
            const heroUrl = post.heroImage?.asset?.url;
            return (
              <article class="group grid grid-cols-1 md:grid-cols-[2fr_3fr] bg-[#1A1A1A] border border-white/10 hover:border-crimson/40 rounded-xl overflow-hidden transition-colors">
                <a href={`/blockblog/${post.slug}`} class="block relative aspect-video md:aspect-auto bg-[#111111] overflow-hidden min-h-[200px]">
                  {heroUrl ? (
                    <img
                      src={heroUrl}
                      alt={post.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-crimson/20 to-[#0D0D0D] flex items-center justify-center">
                      <span class="font-display text-white/20 text-6xl font-bold">FS</span>
                    </div>
                  )}
                </a>
                <div class="flex flex-col p-6">
                  <div class="flex items-center gap-3 mb-3">
                    {cats.map((cat: string) => (
                      <span class={`px-2 py-0.5 text-xs font-bold uppercase tracking-widest rounded border ${categoryColors[cat] ?? 'bg-white/10 text-white/60 border-white/20'}`}>{cat}</span>
                    ))}
                    <span class="text-white/40 text-xs font-body">{formatDate(post.pubDate)}</span>
                    {post.readTime && <span class="text-white/40 text-xs font-body">· {post.readTime}</span>}
                  </div>
                  <a href={`/blockblog/${post.slug}`} class="flex-1">
                    <h2 class="font-display text-xl md:text-2xl font-bold text-white mb-3 leading-tight group-hover:text-crimson-light transition-colors">{post.title}</h2>
                    <p class="text-white/60 text-sm leading-relaxed font-body">{post.description}</p>
                  </a>
                  <div class="mt-4 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-full bg-crimson flex items-center justify-center text-white font-bold text-xs">DD</div>
                      <span class="text-white/40 text-xs font-body">{post.author}</span>
                    </div>
                    <a href={`/blockblog/${post.slug}`} class="text-crimson text-sm font-semibold flex items-center gap-1 hover:gap-2 transition-all">Lesen <span>→</span></a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
