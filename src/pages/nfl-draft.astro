---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wann findet der NFL Draft 2026 statt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der NFL Draft 2026 findet vom 23. bis 25. April 2026 in Pittsburgh, Pennsylvania statt – am Acrisure Stadium und im Point State Park."
      }
    },
    {
      "@type": "Question",
      "name": "Wo kann ich den NFL Draft 2026 in Deutschland live schauen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "RTL überträgt Tag 1 (Runde 1) und Tag 2 (Runden 2–3) live im Free-TV und auf RTL+. Tag 3 ist über NFL+ (Streaming) und den NFL Network abrufbar."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele Runden hat der NFL Draft?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der NFL Draft besteht aus 7 Runden über drei Tage. In jeder Runde haben alle 32 NFL-Teams einen Pick, plus zusätzliche Compensatory Picks. Insgesamt werden ca. 257 Spieler gedraftet."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist ein UDFA (Undrafted Free Agent)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nach dem Draft können Teams Spieler als Undrafted Free Agents (UDFAs) unter Vertrag nehmen, die in keiner der 7 Runden ausgewählt wurden. Viele deutsche Spieler – darunter Kasim Edebali, Jakob Johnson oder Kilian Zierer – schafften ihren NFL-Weg als UDFA. UDFAs werden meistens für Training Camps oder Practice Squads verpflichtet."
      }
    },
    {
      "@type": "Question",
      "name": "Welche deutschen Spieler wurden bisher im NFL Draft ausgewählt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gedraftete deutsche Spieler: Markus Koch (1986, R5, Washington Redskins – 2× Super Bowl), Sebastian Vollmer (2009, R2, Pick 58, Patriots – 2× Super Bowl), Markus Kuhn (2012, R7, Giants), Björn Werner (2013, R1, #24, Colts), Mark Nzeocha (2015, R7, Cowboys), Moritz Böhringer (2016, R6, Vikings – erster Europäer ohne College-Erfahrung), Equanimeous St. Brown (2018, R6, Packers) und Amon-Ra St. Brown (2021, R4, #112, Lions – Pro Bowler)."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen Combine und Pro Day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der NFL Combine ist ein zentrales Scouting-Event im Februar/März in Indianapolis, bei dem eingeladene Top-Prospects athletische Tests absolvieren (40-Yard-Dash, Bench Press, Vertical Jump etc.). Pro Days sind universitätseigene Events, bei denen Scouts direkt an der Uni der Spieler vorbeikommen – wichtig für Spieler, die nicht zum Combine eingeladen wurden."
      }
    },
    {
      "@type": "Question",
      "name": "Was bedeuten die verschiedenen Draft-Runden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Runde 1 (Top-32) enthält die besten Prospects mit garantierten Rookie-Verträgen. Runden 2–3 (Day 2) sind Starter-Kandidaten. Runden 4–7 (Day 3) sind Developmental-Picks, Spezialisten und Risiko-Picks. Nach Runde 7 beginnt die UDFA-Phase."
      }
    }
  ]
};

