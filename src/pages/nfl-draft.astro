const athleticTests = [
  { name: "40-Yard-Dash", desc: "Sprintgeschwindigkeit über ~36 Meter. Maßstab für Explosivität.", example: "WRs unter 4,40s gelten als schnell" },
  { name: "Bench Press (225 lbs)", desc: "Wie viele Wiederholungen schafft ein Spieler mit 102 kg? Misst Kraft und Ausdauer.", example: "OL-Spieler: 25+ Reps erwartet" },
  { name: "Vertical Jump", desc: "Sprungkraft aus dem Stand. Relevant für WRs, DBs, TEs.", example: "36\"+ gilt als elite" },
  { name: "Broad Jump", desc: "Horizontaler Sprung aus dem Stand. Misst Explosivkraft der Beine.", example: "Korreliert mit Run-After-Catch-Ability" },
  { name: "3-Cone-Drill", desc: "Wendigkeitsparcours um drei Kegel. Misst Agilität und Richtungswechsel.", example: "Wichtig für Edge Rusher und DBs" },
  { name: "20-Yard-Shuttle", desc: "5–10–5-Shuttle: Links, rechts, links. Laterale Schnelligkeit.", example: "Standard für nahezu alle Positionen" }
];

const players2026 = [
  { name: "Marlin Klein", pos: "TE", college: "Michigan (Big Ten)", proj: "Runde 3 (Top 100 möglich)", teams: "Eagles, Lions, Falcons, Steelers" },
  { name: "Paul Rubelt", pos: "OT", college: "UCF (Big 12)", proj: "Late Day 3 / UDFA", teams: "~20 Teams kontaktiert" },
  { name: "Mark Petry", pos: "OL", college: "Syracuse (ACC)", proj: "Round 7 / UDFA", teams: "Mehrere Teams" },
  { name: "Florian Staehler", pos: "OG", college: "New Mexico State (CUSA)", proj: "UDFA / Camps", teams: "—" },
  { name: "Maurice Heims", pos: "DE", college: "Idaho (FCS)", proj: "UDFA / Rookie Camp", teams: "Packers, Bears, Broncos, Seahawks" },
  { name: "Felix Lepper", pos: "OL", college: "IPP Program", proj: "Practice Squad (IPP)", teams: "—" },
  { name: "Leo Blumentritt", pos: "P/K", college: "Northern Colorado (FCS)", proj: "UDFA / Camp Chance", teams: "—" }
];

// Historische Jahrgänge
const draft2025 = [
  {
    name: "Leander Wiegand",
    pos: "OT",
    from: "Aachen",
    path: "Aachen Vampires → Cologne Centurions / Rhein Fire / Munich Ravens (ELF) → IPP 2025 → UDFA",
    team: "New York Jets",
    result: "UDFA nach dem Draft. NFL-Debüt in der Preseason gegen die Giants. Waived 26. August, noch am selben Tag auf die Practice Squad re-signed. Verbrachte die Saison 2025 auf der Practice Squad der Jets.",
    badge: "Practice Squad"
  },
  {
