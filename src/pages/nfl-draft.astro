    badge: "Practice Squad"
  }
];

const historySummary = [
  { year: "2022", player: "Marcel Dabo", pos: "CB", team: "Colts (IPP)", note: "Practice Squad 2022–2025." },
  { year: "2021", player: "Aaron Donkor", pos: "DE", team: "Seahawks (IPP)", note: "Practice Squad 2021–2022. Danach XFL, CFL, ELF." },
  { year: "2020", player: "David Bada", pos: "DL", team: "Washington Commanders (IPP)", note: "Weg bis zum Active Roster Dez. 2022." },
  { year: "2019", player: "Jakob Johnson", pos: "FB", team: "Patriots → Raiders → Giants → Texans (IPP/UDFA)", note: "Erster IPP-Spieler mit NFL-TD. 77 Spiele, aktiv bis mind. 2025." },
  { year: "2018", player: "Christopher Ezeala", pos: "RB", team: "Baltimore Ravens (IPP)", note: "Training Camp / Practice Squad." },
  { year: "2017", player: "Eric Nzeocha", pos: "LB", team: "Tampa Bay Buccaneers (IPP)", note: "Practice Squad 2017–2018." },
  { year: "2016", player: "Moritz Böhringer", pos: "WR/TE", team: "Minnesota Vikings → Bengals (Draft R6, #180)", note: "Erster Europäer im NFL Draft ohne US-College-Erfahrung." },
  { year: "2015", player: "Mark Nzeocha", pos: "LB", team: "Cowboys → 49ers (Draft R7, #236)", note: "Super Bowl LIV mit San Francisco. Karriere-Int. gegen Jameis Winston 2019." },
  { year: "2013", player: "Björn Werner", pos: "DE", team: "Indianapolis Colts (Draft R1, #24)", note: "Höchster je gedrafteter Deutschstämmiger. Via US-Highschool und Florida State." },
  { year: "2009", player: "Sebastian Vollmer", pos: "OT", team: "New England Patriots (UDFA)", note: "2× Super Bowl Champion. Pro Bowl 2015. Die Blaupause für den NCAA-Weg." },
];

const glossary = [
  { term: "Draft Pick", def: "Das Auswahlrecht eines Teams in einer bestimmten Runde. Picks können getradet werden." },
  { term: "Compensatory Pick", def: "Extra-Picks, die Teams erhalten, wenn sie im Vorjahr mehr gute Free Agents verloren als gewonnen haben. Meist in Runde 3–7." },
  { term: "UDFA", def: "Undrafted Free Agent – Spieler, der nach dem Draft von keinem Team ausgewählt wurde, aber trotzdem einen Vertrag (meist für Training Camp) bekommt." },
  { term: "Rookie Contract", def: "4-Jahres-Standardvertrag für gedraftete Spieler. Runde-1-Picks haben eine 5th-Year-Option für das Team." },
  { term: "Bust", def: "Ein hoch gedrafteter Spieler, der die Erwartungen weit verfehlt." },
  { term: "Sleeper", def: "Ein spät gedrafteter oder undrafted Spieler, der überraschend gut wird." },
  { term: "Big Board", def: "Die interne Rangliste der besten Prospects eines Teams – unabhängig von Positionen." },
  { term: "Mock Draft", def: "Spekulativer Entwurf: Journalisten und Analysten versuchen vorherzusagen, wer wo landet." },
  { term: "RAS", def: "Relative Athletic Score – kombinierte Athletik-Bewertung (0–10) auf Basis der Combine-Zahlen im Positionsvergleich." },
  { term: "Practice Squad", def: "10–16 Spieler pro Team, die trainieren aber kein aktives Roster-Mitglied sind. Sprungbrett in den 53-Mann-Kader." },
  { term: "IPP", def: "NFL International Player Pathway Programme – Programm der NFL für internationale Talente ohne US-College-Erfahrung." },
  { term: "Reserve/Futures Contract", def: "Vertrag, der nach Saisonende geschlossen wird und ab dem nächsten Training Camp gilt. Zeigt, dass ein Team an einem Spieler festhält." }
];
---

<BaseLayout
  title="NFL Draft Guide – Ablauf, Runden, Deutsche Spieler | Footballschland"
  description="Der große NFL Draft Guide auf Deutsch: Ablauf, Runden, Combine, Pro Days, historische und aktuelle deutsche Spieler – alles was du als Fan wissen musst."
  canonical="https://footballschland.de/nfl-draft/"
>
  <!-- noindex: Seite noch in Entwicklung -->
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <!-- Hero -->
  <section class="bg-[#231f20] pt-32 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <p class="text-rot text-xs font-bold uppercase tracking-widest mb-3">Guide · NFL Draft</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
        Der NFL Draft: Alles was du wissen musst
      </h1>
      <p class="text-white/60 text-lg font-body leading-relaxed mb-8">
        Wie der Draft funktioniert, was Combine und Pro Days bedeuten, welche Deutschen je gedraftet wurden – und wer beim nächsten Draft seine Chance bekommt.
      </p>
      <!-- Schnellnavigation -->
      <nav class="flex flex-wrap gap-3">
        {[
          ['Ablauf', '#ablauf'],
          ['Combine & Pro Days', '#combine'],
          ['Draft 2026', '#draft-2026'],
          ['Jahrgänge', '#jahrgaenge'],
          ['Glossar', '#glossar'],
          ['FAQ', '#faq'],
        ].map(([label, href]) => (
          <a href={href} class="text-xs font-bold uppercase tracking-widest text-white/50 hover:text-rot transition-colors border border-white/10 rounded-full px-4 py-1.5">{label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Was ist der NFL Draft -->
  <section class="bg-[#faf8f5] py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-[#231f20] mb-6">Was ist der NFL Draft?</h2>
      <p class="text-[#231f20]/75 font-body leading-relaxed mb-4">
        Der NFL Draft ist das wichtigste Transferevent im American Football. Jedes Jahr im April wählen alle 32 NFL-Teams reihum College-Spieler aus, die sich für die Profiliga qualifiziert haben. Der Draft besteht aus 7 Runden über drei Tage – insgesamt werden ca. 257 Spieler ausgewählt.
      </p>
      <p class="text-[#231f20]/75 font-body leading-relaxed mb-4">
        Das Prinzip dahinter ist simpel: Je schlechter ein Team in der Vorsaison abgeschnitten hat, desto früher darf es picken. Das soll die Liga ausgeglichen halten und Rebuilding-Teams die Chance geben, Top-Talente zu verpflichten. Die Reihenfolge in Runde 1 ist umgekehrt zur Abschlusstabelle der letzten Saison.
      </p>
      <p class="text-[#231f20]/75 font-body leading-relaxed">
        Der Draft existiert seit 1936. Heute ist er eines der meistgesehenen Sportereignisse in den USA – die erste Runde zieht regelmäßig mehr als 12 Millionen TV-Zuschauer.
      </p>
    </div>
  </section>

  <!-- Ablauf -->
  <section id="ablauf" class="bg-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-[#231f20] mb-2">Wie läuft der Draft ab?</h2>
      <p class="text-[#231f20]/55 font-body text-sm mb-8">7 Runden, 3 Tage, 32 Teams</p>

      <div class="space-y-4 mb-12">
        {draftDays.map((d) => (
          <div class="rounded-2xl border border-[#231f20]/8 p-6 bg-[#faf8f5]">
            <div class="flex items-start gap-4">
              <div class="shrink-0 text-center">
                <span class="block font-display text-2xl font-bold text-rot">{d.day}</span>
                <span class="text-xs text-[#231f20]/45 font-body">{d.date}</span>
              </div>
              <div>
                <p class="font-display font-bold text-[#231f20] text-lg mb-1">{d.rounds} <span class="text-[#231f20]/40 font-body font-normal text-sm">({d.picks})</span></p>
                <p class="text-[#231f20]/65 font-body text-sm leading-relaxed">{d.note}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <h3 class="font-display text-xl font-bold text-[#231f20] mb-4">Picks traden</h3>
      <p class="text-[#231f20]/75 font-body leading-relaxed mb-4">
        Teams können ihre Picks frei handeln – auch über mehrere Jahre hinweg. Ein Team kann z.B. seinen 1st-Round-Pick 2026 für den 1st-Round-Pick 2027 plus weitere Picks tauschen. Damit können Teams „Trade Up" (früher picken, mehr Picks abgeben) oder „Trade Down" (später picken, mehr Picks sammeln).
      </p>
      <p class="text-[#231f20]/75 font-body leading-relaxed">
        <strong>Compensatory Picks</strong> sind Zusatzpicks, die die NFL an Teams vergibt, die in der Free Agency mehr hochwertige Spieler verloren als gewonnen haben. Sie werden am Ende der Runden 3–7 hinzugefügt.
      </p>
    </div>
  </section>

  <!-- Combine & Pro Days -->
  <section id="combine" class="bg-[#231f20] py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-white mb-2">Combine & Pro Days</h2>
      <p class="text-white/50 font-body text-sm mb-8">Der Weg vor dem Draft</p>

      <div class="mb-10">
        <h3 class="font-display text-xl font-bold text-white mb-3">NFL Scouting Combine</h3>
        <p class="text-white/65 font-body leading-relaxed mb-4">
          Jedes Jahr im Februar/März versammeln sich die eingeladenen Top-Prospects (ca. 300–330 Spieler) in Indianapolis. Dort absolvieren sie athletische Tests, Positionstraining, medizinische Checks und Interviews mit NFL-Teams. Die Ergebnisse beeinflussen die Draft-Projektion erheblich.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {athleticTests.map((t) => (
            <div class="rounded-xl bg-white/5 border border-white/10 p-4">
              <p class="font-display font-bold text-white text-sm mb-1">{t.name}</p>
              <p class="text-white/55 font-body text-xs leading-relaxed mb-2">{t.desc}</p>
              <p class="text-rot text-xs font-bold">{t.example}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="font-display text-xl font-bold text-white mb-3">Pro Days</h3>
        <p class="text-white/65 font-body leading-relaxed mb-4">
          Pro Days sind universitätseigene Scouting-Events, bei denen Scouts und Coaches der NFL-Teams direkt an die jeweilige Uni reisen. Spieler können dort Combine-Messungen wiederholen oder nachholen – besonders wichtig für Spieler, die nicht zum Combine eingeladen wurden.
        </p>
        <p class="text-white/65 font-body leading-relaxed">
          Für <strong class="text-white">deutsche Spieler</strong> sind Pro Days besonders relevant: Wer aus der GFL oder ELF kommt und noch studiert, kann seinen Pro Day an einer US-Uni nutzen, um sich NFL-Scouts zu präsentieren – oder über das IPP-Programm einen separaten Pro Day abhalten.
        </p>
      </div>
    </div>
  </section>

  <!-- Draft 2026 Aktuell -->
  <section id="draft-2026" class="bg-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-rot/10 text-rot rounded-full px-4 py-1.5 mb-4">
        <span class="w-2 h-2 bg-rot rounded-full inline-block"></span>
        <span class="text-xs font-bold uppercase tracking-widest font-body">Aktuell</span>
      </div>
      <h2 class="font-display text-3xl font-bold text-[#231f20] mb-2">NFL Draft 2026</h2>
      <p class="text-[#231f20]/55 font-body text-sm mb-8">Dieser Abschnitt wird jährlich aktualisiert.</p>

      <div class="rounded-2xl border border-[#231f20]/8 bg-[#faf8f5] p-6 mb-8">
        <h3 class="font-display text-lg font-bold text-[#231f20] mb-4">Datum, Ort & TV</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-rot mb-1 font-body">Datum</p>
            <p class="font-display font-bold text-[#231f20]">23.–25. April 2026</p>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-rot mb-1 font-body">Ort</p>
            <p class="font-display font-bold text-[#231f20]">Pittsburgh, PA</p>
            <p class="text-[#231f20]/55 font-body text-xs">Acrisure Stadium &amp; Point State Park</p>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-rot mb-1 font-body">TV (Deutschland)</p>
            <p class="font-display font-bold text-[#231f20]">RTL / RTL+</p>
            <p class="text-[#231f20]/55 font-body text-xs">Tag 1 &amp; 2 live im Free-TV</p>
          </div>
        </div>
      </div>

      <h3 class="font-display text-xl font-bold text-[#231f20] mb-4">Deutsche Kandidaten 2026</h3>
      <p class="text-[#231f20]/65 font-body text-sm leading-relaxed mb-6">
        Sieben deutsche Spieler haben realistische Chancen auf einen NFL-Vertrag – entweder via Draft oder als UDFA. Die Ausnahme: <strong>Marlin Klein</strong> (TE, Michigan) gilt als echter Draft-Kandidat und könnte sogar in den Top 100 landen.
      </p>

      <div class="overflow-x-auto rounded-2xl border border-[#231f20]/8">
        <table class="w-full text-sm font-body">
          <thead>
            <tr style="background-color:#231f20;">
