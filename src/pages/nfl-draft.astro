const draft2024 = [
  {
    name: "Lorenz Metz",
    pos: "OT",
    from: "Deutschland",
    path: "GFL/ELF → IPP 2024",
    team: "Tampa Bay Buccaneers → New England Patriots",
    result: "Signed 15. April 2024 bei Tampa Bay via IPP. Verbrachte die Saison 2024 auf der Practice Squad der Buccaneers. Waived August 2025, sofort re-signed auf Practice Squad. Im Januar 2026 Reserve/Futures-Vertrag mit den New England Patriots – wo die Reise weitergeht.",
    badge: "Practice Squad → Patriots 2026"
  },
  {
    name: "Julius Welschof",
    pos: "LB/DE",
    from: "Miesbach, Bayern",
