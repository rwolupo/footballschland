];

const draft2023 = [
  {
    name: "David Bada",
    pos: "DL",
    from: "Deutschland",
    path: "GFL/ELF → IPP 2020 (Washington Commanders) → aktiver Kader Dez. 2022",
    team: "Washington Commanders",
    result: "Das große Highlight vor dem 2023er Draft-Jahr: Im Dezember 2022 erstmals auf den Active Roster der Commanders befördert – ein echter Meilenstein für einen IPP-Spieler. Im August 2023 Training Camp mit den Commanders, aber Trizepsverletzung beendete die Saison frühzeitig. Im Juli 2024 Wechsel zu den Detroit Lions.",
    badge: "Active Roster (Dez. 2022)"
  },
  {
    name: "Marcel Dabo",
