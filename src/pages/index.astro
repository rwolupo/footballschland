---
export const prerender = true;
import { sanityClient } from '../lib/sanity';
import { ALL_POSTS_QUERY } from '../lib/queries';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await sanityClient.fetch(ALL_POSTS_QUERY);
const latestPosts = allPosts.slice(0, 3);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const categoryColors: Record<string, string> = {
  Draft: 'bg-crimson/20 text-crimson border-crimson/40',
  'NFL Draft': 'bg-crimson/20 text-crimson border-crimson/40',
  NFL: 'bg-blue-900/50 text-blue-400 border-blue-700',
  College: 'bg-emerald-900/50 text-emerald-400 border-emerald-700',
  Feature: 'bg-white/10 text-white/60 border-white/20',
};

const podcastPlatforms = [
  {
    name: 'Spotify',
    url: 'https://open.spotify.com/show/1DlSNLB5HsxSp12nilwjbc',
    color: '#1DB954',
    imgSrc: null as string | null,
    icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.36-.66.48-1.021.24-2.82-1.74-6.36-2.1-10.561-1.14-.418.12-.779-.18-.899-.54-.12-.42.18-.78.54-.9 4.56-1.02 8.52-.6 11.64 1.32.42.18.479.66.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.32-1.32 9.72-.66 13.44 1.56.36.18.54.78.241 1.2zm.12-3.36c-3.84-2.28-10.26-2.52-13.92-1.38-.6.18-1.2-.18-1.38-.72-.18-.6.18-1.2.72-1.38 4.26-1.26 11.28-1.02 15.72 1.62.54.3.72 1.02.42 1.56-.3.42-1.02.6-1.56.3z"/></svg>',
  },
  {
    name: 'Apple Podcasts',
    url: 'https://podcasts.apple.com/de/podcast/footballschland-american-football-made-in-germany/id1674301287',
    color: '#B150E2',
    imgSrc: null as string | null,
    icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M12 1a4 4 0 0 1 4 4v6a4 4 0 1 1-8 0V5a4 4 0 0 1 4-4zm-1 19v-2.07A7 7 0 0 1 5 11h2a5 5 0 0 0 10 0h2a7 7 0 0 1-6 6.93V20h2v2H9v-2h2z"/></svg>',
  },
  {
    name: 'Amazon Music',
    url: 'https://music.amazon.de/podcasts/30356913-e520-4ebe-aaf9-4ae2f8a260ea/footballschland-american-football-made-in-germany',
    color: '#00A8E0',
    imgSrc: '/assets/logos/icon-amazonmusic.svg',
    icon: null as string | null,
  },
  {
    name: 'RTL+',
    url: 'https://plus.rtl.de/podcast/footballschland-american-football-made-in-germany-qb6ejviehu3ee',
    color: '#E4002B',
    imgSrc: '/assets/logos/icon-rtlplus.svg',
    icon: null as string | null,
  },
  {
    name: 'Castbox',
    url: 'https://castbox.fm/vh/6522348',
    color: '#F55B23',
    imgSrc: null as string | null,
    icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M3 18h2V6H3v12zm4 0h2v-7H7v7zm4 0h2V3h-2v15zm4 0h2V8h-2v10zm4 0h2v-5h-2v5z"/></svg>',
  },
  {
    name: 'RSS Feed',
    url: 'https://feeds.megaphone.fm/footballschland',
    color: '#F26522',
    imgSrc: null as string | null,
    icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>',
  },
];
---
<BaseLayout
  title="Footballschland – American Football MADE IN GERMANY"
  description="Deutschlands führender Podcast über deutsche Talente im American Football – High School, College, NFL, GFL & ELF. Jetzt reinhören auf Spotify & Apple Podcasts."
  canonical="https://footballschland.de"
>
  <!-- ── HERO ── -->
  <section class="relative min-h-[88vh] flex flex-col items-center justify-center bg-[#0D0D0D] pt-20 pb-24 px-4 overflow-hidden">
    <!-- Hero background image -->
    <img
      src="/assets/68905713-9FA5-4E4D-8C05-461526D5BB1D_1_102_o (1).jpeg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center opacity-25 pointer-events-none"
      aria-hidden="true"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D0D0D]/60 via-[#0D0D0D]/30 to-[#0D0D0D]/80 pointer-events-none"></div>
    <div class="absolute top-1/3 right-0 w-[600px] h-[600px] bg-crimson/6 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-[500px] h-[500px] bg-gold/4 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(35,31,32,0)_0%,_rgba(13,13,13,0.8)_70%)] pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center max-w-5xl mx-auto">
      <img
        src="/assets/logos/footballschland.svg"
        alt="Footballschland"
        class="w-36 md:w-52 lg:w-64 mb-10 drop-shadow-2xl"
      />
      <div class="flex justify-center gap-1.5 mb-8">
        <div class="w-8 h-1.5 rounded-full bg-white/20"></div>
        <div class="w-8 h-1.5 rounded-full bg-crimson"></div>
        <div class="w-8 h-1.5 rounded-full bg-gold"></div>
      </div>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        American Football<br />
        <span class="text-crimson">MADE IN GERMANY</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/60 max-w-3xl mx-auto mb-10 font-body leading-relaxed">
        Der Podcast, der die Geschichten von deutschen Talenten in High School, College und NFL erzählt.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/episoden" class="btn-episodes">Episoden ansehen</a>
        <a href="https://www.patreon.com/footballschland" target="_blank" rel="noopener noreferrer" class="btn-patreon">❤️ Unterstützen</a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 pointer-events-none">
      <span class="text-[10px] uppercase tracking-[0.3em] font-body">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/20 to-transparent"></div>
    </div>
  </section>

  <!-- ── AKTUELLE FOLGE ── -->
  <section class="bg-[#111111] py-16 px-4 border-b border-white/10">
    <div class="max-w-3xl mx-auto">
      <h2 class="section-label text-center mb-4">Footballschland Podcast</h2>
      <h3 class="font-display text-3xl md:text-4xl font-bold text-white text-center mb-8 leading-tight">
        Aktuelle <span class="text-crimson">Folge</span>
      </h3>
      <!-- Placeholder (sichtbar solange kein Consent) -->
      <div class="consent-placeholder rounded-xl bg-white/5 border border-white/10 p-8 text-center space-y-4">
        <div class="text-4xl">🎙</div>
        <p class="text-white/70 text-sm font-semibold">Spotify-Player</p>
        <p class="text-white/45 text-xs leading-relaxed max-w-xs mx-auto">
          Zum Laden des Podcast-Players ist deine Zustimmung zu externen Inhalten erforderlich.
        </p>
        <button onclick="fsConsentAccept()" class="btn-primary text-sm py-2 px-5">
          Akzeptieren &amp; laden
        </button>
      </div>
      <!-- Actual player (hidden until consent) -->
      <div class="consent-content" style="display:none">
        <iframe
          style="border-radius:12px"
          data-consent-src="https://open.spotify.com/embed/show/1DlSNLB5HsxSp12nilwjbc?utm_source=generator&theme=0"
          width="100%"
          height="232"
          frameBorder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ── PLATTFORMEN ── -->
  <section class="bg-[#0D0D0D] py-12 px-4 border-b border-white/10">
    <div class="max-w-5xl mx-auto">
      <h3 class="font-display text-3xl md:text-4xl font-bold text-white text-center mb-8 leading-tight">
        Überall <span class="text-gold">verfügbar</span>
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {podcastPlatforms.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-3 p-5 rounded-xl border bg-white/5 hover:bg-white/10 transition-all duration-300"
            style={`border-color: ${platform.color}55`}
          >
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center"
              style={`background-color: ${platform.color}20; color: ${platform.color}`}
            >
              {platform.imgSrc
                ? <img src={platform.imgSrc} alt={platform.name} class="w-7 h-7 object-contain" />
                : <Fragment set:html={platform.icon} />
              }
            </div>
            <span class="text-white/70 group-hover:text-white font-semibold text-xs text-center transition-colors leading-tight">
              {platform.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── DIVIDER ── -->
  <div class="section-divider bg-[#0D0D0D]" aria-hidden="true">
    <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, rgba(255,255,255,0.06))"></div>
    <div class="flex flex-col gap-[4px] mx-8">
      <div class="w-20 h-[2px] rounded-full bg-[#231f20]"></div>
      <div class="w-20 h-[2px] rounded-full bg-crimson/40"></div>
      <div class="w-20 h-[2px] rounded-full bg-gold/40"></div>
    </div>
    <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, rgba(255,255,255,0.06))"></div>
  </div>

  <!-- ── SANDRA & DANIEL ── -->
  <section class="py-24 px-4 relative overflow-hidden">
    <!-- Atmospheric background -->
    <div class="absolute inset-0 z-0">
      <img src="/assets/2A2398A4-1B9D-4324-B019-86F162E11EC4_1_105_c.jpeg" alt="" class="w-full h-full object-cover opacity-15" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0D0D0D]/85 via-[#0D0D0D]/60 to-[#0D0D0D]/85"></div>
    </div>
    <div class="max-w-4xl mx-auto relative z-10">
      <h2 class="section-label text-center">Über uns</h2>
      <div class="flex justify-center gap-10 md:gap-20 mt-10 mb-14">
        <div class="flex flex-col items-center gap-4">
          <div class="w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden shadow-2xl ring-2 ring-crimson/30">
            <img src="/assets/fbs%20sandra_edited.jpg" alt="Sandra Janat" class="w-full h-full object-cover object-top" />
          </div>
          <span class="text-white/50 text-sm font-body tracking-wide">Sandra Janat</span>
        </div>
        <div class="flex flex-col items-center gap-4">
          <div class="w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden shadow-2xl ring-2 ring-gold/30">
            <img src="/assets/fbs%20daniel_edited_edited.jpg" alt="Daniel Düngel" class="w-full h-full object-cover object-top" />
          </div>
          <span class="text-white/50 text-sm font-body tracking-wide">Daniel Düngel</span>
        </div>
      </div>
      <div class="space-y-5 text-center max-w-3xl mx-auto">
        <p class="text-lg text-white/80 leading-relaxed font-body">
          Wir sind Sandra und Daniel – und wir lieben American Football. Besonders fasziniert uns die Spur deutscher Talente im amerikanischen Football. Seit vielen Jahren begleiten wir junge Athletinnen und Athleten, die den mutigen Schritt über den Atlantik wagen – mit dem Ziel, ihren Traum zu leben.
        </p>
        <p class="text-lg text-white/65 leading-relaxed font-body">
          Was für uns so richtig in den Appalachen Georgias begann, endet heute für einige dieser vielversprechenden Talente in der National Football League.
        </p>
        <p class="text-lg text-white/65 leading-relaxed font-body">
          Aus erster Neugier wurde eine echte Leidenschaft: Wir erzählen die Geschichten hinter den Helmen – von High School über College bis zur NFL. Geschichten voller Mut, Rückschläge, Triumphe – und vor allem: voller Menschlichkeit.
        </p>
        <p class="text-lg text-white/90 font-semibold italic leading-relaxed font-body pt-2">
          Footballschland – der Blick hinter die Kulissen von Football MADE IN GERMANY.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
        <a href="/episoden" class="btn-episodes">Episoden ansehen</a>
        <a href="https://www.patreon.com/footballschland" target="_blank" rel="noopener noreferrer" class="btn-patreon">❤️ Unterstützen</a>
      </div>
    </div>
  </section>


  <!-- ── DIVIDER ── -->
  <div class="section-divider bg-[#0D0D0D]" aria-hidden="true">
    <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, rgba(255,255,255,0.06))"></div>
    <div class="flex flex-col gap-[4px] mx-8">
      <div class="w-20 h-[2px] rounded-full bg-[#231f20]"></div>
      <div class="w-20 h-[2px] rounded-full bg-crimson/40"></div>
      <div class="w-20 h-[2px] rounded-full bg-gold/40"></div>
    </div>
    <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, rgba(255,255,255,0.06))"></div>
  </div>

  <!-- ── BLOCKBLOG ── -->
  <section class="py-20 px-4 bg-[#0D0D0D]">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="section-label">Blockblog</h2>
          <h3 class="font-display text-3xl md:text-4xl font-bold text-white mt-2 leading-tight">
            Aktuelle <span class="text-gold">Artikel</span>
          </h3>
        </div>
        <a href="/blockblog" class="text-white/40 hover:text-white text-xs font-medium uppercase tracking-widest transition-colors">Alle Artikel →</a>
      </div>
      {latestPosts.length === 0 ? (
        <p class="text-white/40 text-center py-12">Keine Artikel gefunden.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post: any) => {
            const heroUrl = post.heroImage?.asset?.url;
            const badgeClass = categoryColors[post.category] ?? 'bg-white/10 text-white/60 border-white/20';
            return (
              <article class="group bg-[#1A1A1A] border border-white/10 hover:border-crimson/40 rounded-xl overflow-hidden transition-all duration-300 flex flex-col">
                <a href={`/blockblog/${post.slug}`} class="block aspect-video relative bg-[#111111] overflow-hidden">
                  {heroUrl
                    ? <img src={heroUrl} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    : <div class="w-full h-full bg-gradient-to-br from-crimson/20 to-[#0D0D0D] flex items-center justify-center"><span class="font-display text-white/20 text-5xl font-bold">FS</span></div>
                  }
                </a>
                <div class="flex flex-col flex-1 p-5">
                  <div class="flex items-center gap-2 mb-3 flex-wrap">
                    <span class={`px-2 py-0.5 text-xs font-bold uppercase tracking-widest rounded border ${badgeClass}`}>{post.category}</span>
                    <span class="text-white/40 text-xs font-body">{formatDate(post.pubDate)}</span>
                  </div>
                  <a href={`/blockblog/${post.slug}`} class="flex-1">
                    <h3 class="font-display text-lg font-bold text-white mb-2 leading-tight group-hover:text-crimson-light transition-colors line-clamp-3">{post.title}</h3>
                  </a>
                  <a href={`/blockblog/${post.slug}`} class="mt-3 text-crimson text-sm font-semibold flex items-center gap-1 hover:gap-2 transition-all self-start">Lesen <span>→</span></a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- ── DIVIDER ── -->
  <div class="section-divider bg-gradient-to-b from-[#0D0D0D] to-[#111111]" aria-hidden="true">
    <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, rgba(255,255,255,0.06))"></div>
    <div class="flex flex-col gap-[4px] mx-8">
      <div class="w-20 h-[2px] rounded-full bg-[#231f20]"></div>
      <div class="w-20 h-[2px] rounded-full bg-crimson/40"></div>
      <div class="w-20 h-[2px] rounded-full bg-gold/40"></div>
    </div>
    <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, rgba(255,255,255,0.06))"></div>
  </div>

  <!-- ── UNTERSTÜTZE UNS ── -->
  <section class="py-24 px-4 bg-gradient-to-b from-[#111111] to-[#0D0D0D] border-t border-white/10 relative overflow-hidden">
    <!-- Atmospheric glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-crimson/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto relative z-10">

      <!-- Label + Headline -->
      <h2 class="section-label text-center mb-4">Unsere Mission</h2>
      <h3 class="font-display text-4xl md:text-5xl font-bold text-white text-center mb-14 leading-tight">
        Unterstütze <span class="text-crimson">uns</span>
      </h3>

      <!-- Schwarzrotgold accent bar -->
      <div class="flex h-[3px] w-24 mx-auto mb-12 rounded-full overflow-hidden">
        <div class="flex-1 bg-[#231f20]"></div>
        <div class="flex-1 bg-rot"></div>
        <div class="flex-1 bg-gold"></div>
      </div>

      <!-- Text -->
      <div class="space-y-6 font-body text-base md:text-lg leading-relaxed">
        <p class="text-white/90 font-semibold text-xl md:text-2xl leading-snug">
          Footballschland ist mehr als ein Podcast.
        </p>
        <p class="text-white/65">
          Wir erzählen die Geschichten junger deutscher Football-Talente, die den mutigen Weg von High School und College Football bis in die NFL gehen – und damit einen Traum leben, den viele für unerreichbar halten. Wir begleiten sie, sprechen mit ihren Familien, Coaches und Wegbegleiter:innen. Und wir zeigen: Schwarz-Rot-Gold hat im American Football eine Zukunft.
        </p>
        <p class="text-white/55">
          Diese Geschichten verdienen es, gehört zu werden. Aber: Qualität, Tiefe und Reichweite entstehen nicht einfach so nebenbei.
        </p>

        <!-- Highlight box -->
        <div class="my-8 p-6 rounded-xl border border-white/10 bg-white/5">
          <p class="text-white font-semibold mb-3">🎙 Was wir tun, kostet Zeit, Herzblut und Geld.</p>
          <p class="text-white/60 text-sm leading-relaxed">
            Ob Interviews mit den Spielern, technische Ausstattung, Recherche, Postproduktion oder die Aufbereitung der Inhalte – all das stemmen wir in unserer Freizeit und ohne Budgets.
          </p>
        </div>

        <p class="text-white/70 font-semibold">
          Deshalb brauchen wir dich.
        </p>
        <p class="text-white/55">
          Wenn dir unser Podcast gefällt, wenn du die Vision teilst, deutsche Talente sichtbar zu machen und dem Football hierzulande eine Bühne zu geben, dann hilf uns, Footballschland weiter auszubauen.
        </p>

        <div class="my-8 p-6 rounded-xl border border-crimson/20 bg-crimson/5">
          <p class="text-white font-semibold mb-2">👊 Werde Teil unserer Mission.</p>
          <p class="text-white/65 text-sm leading-relaxed">
            Mit deiner Unterstützung auf Patreon hilfst du uns, unabhängig, hochwertig und regelmäßig neue Inhalte zu produzieren – für dich, für die Community und für all die Spieler:innen, die gerade den nächsten Schritt wagen.
          </p>
        </div>

        <div class="text-center py-4">
          <p class="text-white/80 font-semibold text-lg mb-1">❤️ Jede Unterstützung zählt.</p>
          <p class="text-white/50 text-sm">
            Ob einmalig oder monatlich – du hilfst uns, den Traum vom „American Football MADE IN GERMANY" weiterzuerzählen.
          </p>
        </div>
      </div>

      <!-- CTAs -->
      <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center flex-wrap">
        <a
          href="https://www.patreon.com/footballschland"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-patreon text-base px-8 py-4"
        >
          ❤️ Auf Patreon unterstützen
        </a>
        <a
          href="https://shop.footballschland.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-base px-8 py-4"
        >
          🛍 Shop besuchen
        </a>
        <a
          href="/partner"
          class="btn-gold text-base px-8 py-4"
        >
          🤝 Unsere Partner
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="py-20 px-4 bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="section-label text-center mb-4">Unsere Mission</h2>
      <h3 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">
        Sei Teil der <span class="text-gold">Community</span>
      </h3>
      <p class="text-lg text-white/60 mb-8 max-w-2xl mx-auto font-body">
        Folge uns auf Social Media, abonniere unseren Podcast und unterstütze uns auf Patreon.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.instagram.com/footballschland" target="_blank" rel="noopener noreferrer" class="btn-outline">Instagram</a>
